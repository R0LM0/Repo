# Configuración de finales de línea
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf
.gitignore text eol=crlf
.gitattributes text eol=crlf

# Archivos binarios
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary

# Archivos de imagen
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=crlf

# Archivos de configuración
*.user binary
*.suo binary
*.userosscache binary
