        <dependency id="Microsoft.EntityFrameworkCore" version="9.0.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.EntityFrameworkCore.SqlServer" version="9.0.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Caching.StackExchangeRedis" version="9.0.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="9.0.6" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
